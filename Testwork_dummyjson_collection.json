          "name": "Получение токена (auth/login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.environment.set(\"TestToken\", pm.response.json().accessToken);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{TestToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n\"username\": \"emilys\",\r\n\"password\": \"emilyspass\",\r\n\"expiresInMins\": 60 // optional, defaults to 60\r\n}\r\n\r\n",
